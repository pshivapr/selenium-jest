{
    "name": "selenium-jest",
    "version": "1.0.0",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "test": "jest",
        "test:parallel": "jest --maxWorkers=4",
        "test:sequential": "jest --runInBand",
        "test:headed": "cross-env HEADLESS=false jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:coverage:open": "jest --coverage && start ./coverage/lcov-report/index.html",
        "test:report": "jest && start ./test-results/test-report.html",
        "test:report:open": "start ./test-results/test-report.html",
        "test:a11y": "jest tests/accessibility.test.ts",
        "test:a11y:open": "start ./test-results/accessibility"
    },
    "dependencies": {
        "axios": "^1.13.5",
        "selenium-webdriver": "^4.40.0"
    },
    "devDependencies": {
        "@axe-core/webdriverjs": "^4.11.1",
        "@faker-js/faker": "^10.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.2.3",
        "@types/selenium-webdriver": "^4.35.5",
        "axe-core": "^4.11.1",
        "axe-html-reporter": "^2.2.11",
        "chromedriver": "^145.0.1",
        "cross-env": "^10.1.0",
        "geckodriver": "^6.1.0",
        "jest": "^30.2.0",
        "jest-html-reporter": "^4.3.0",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}